rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Single admin UID for dev seed actions
    function isAdmin() {
      return isSignedIn() && request.auth.uid == "CKz2MS0kdaWLbBIaAAVsJGKJqFL2";
    }

    // Shared exercise catalog
    match /global_exercises/{exerciseId} {
      // All authenticated users can read global exercises.
      allow read: if isSignedIn();
      // Writes restricted to admin-only seed flows.
      allow create, update, delete: if isAdmin();
    }

    // Shared running types catalog
    match /global_running_types/{runningTypeId} {
      // All authenticated users can read running types.
      allow read: if isSignedIn();
      // Writes restricted to admin-only seed flows.
      allow create, update, delete: if isAdmin();
    }

    // Root user document: users/{uid}
    match /users/{uid} {
      // Profile / account doc
      allow read, create, update, delete: if isOwner(uid);

      // Exercises
      match /exercises/{exerciseId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      // Workout templates
      match /workout_templates/{templateId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      // Workout sessions
      match /workout_sessions/{sessionId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      // Body weight entries
      match /body_weight_entries/{entryId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      // Body measurement entries
      match /body_measurement_entries/{entryId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      // Body check-ins
      match /body_checkins/{checkinId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      // Deny any other unknown subcollection under users/{uid}
      match /{subCollection}/{docId} {
        allow read, write: if false;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
